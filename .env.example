# n8n Morning Intelligence Briefing - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# AI API Keys (at least one required)
# ============================================================

# Anthropic Claude API Key (PRIMARY - recommended)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API Key (FALLBACK)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini API Key (FALLBACK)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# ============================================================
# AI Model Configuration (optional)
# ============================================================

# Claude model to use for analysis
# Options: claude-sonnet-4-6-20250514, claude-3-5-sonnet-latest, claude-3-opus-latest
N8N_CLAUDE_MODEL=claude-sonnet-4-6-20250514

# OpenAI model (if Claude fails)
N8N_OPENAI_MODEL=gpt-4o

# Gemini model (if both Claude and OpenAI fail)
N8N_GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Slack Configuration
# ============================================================

# Slack Bot OAuth Token
# Get from: https://api.slack.com/apps > Your App > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Target Slack channel for briefings
SLACK_CHANNEL=#morning-digest

# ============================================================
# Gmail OAuth2 (configure in n8n credentials UI)
# These are only needed if using env vars instead of UI
# ============================================================

# Gmail OAuth2 Access Token (short-lived, managed by n8n)
# GMAIL_ACCESS_TOKEN=

# ============================================================
# Outlook OAuth2 (configure in n8n credentials UI)
# ============================================================

# Outlook OAuth2 Access Token (short-lived, managed by n8n)
# OUTLOOK_ACCESS_TOKEN=

# ============================================================
# n8n Configuration
# ============================================================

# Timezone for scheduling
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# Allow filesystem access for Obsidian integration
NODE_FUNCTION_ALLOW_BUILTIN=fs,path

# Disable secure cookie for local development
N8N_SECURE_COOKIE=false

# ============================================================
# Obsidian Vault Path (for Docker volume mounting)
# ============================================================

# Path to your Obsidian vault on the host machine
# This is mounted as /data/obsidian-vault in the container
OBSIDIAN_VAULT_PATH=C:/Users/aryan/OneDrive/Documents/Obsidian Vault

# ============================================================
# Email Delivery Configuration
# ============================================================

# Email address to send digest to
DIGEST_EMAIL_TO=aryanrheasingh@gmail.com
